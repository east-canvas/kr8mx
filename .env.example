# KR8MX environment

# --- Active ---
# Neon Postgres connection string (Drizzle ORM, COA + barcode admin, carts).
DATABASE_URL=

# --- Needed to enable the KR8MX admin console (/admin) ---
# Single shared admin password. If unset, the admin is locked (secure default).
ADMIN_PASSWORD=

# --- Optional ---
# Canonical site origin. Used for metadata/sitemap/robots and barcode scan URLs.
# Only the ORIGIN is used (a path is ignored). Falls back to VERCEL_URL, then
# localhost. Defaults to https://www.kr8mx.com for barcodes.
NEXT_PUBLIC_SITE_URL=

# --- Email (Resend; falls back to a mock outbox when unset) ---
# When RESEND_API_KEY is set, transactional + announcement emails send for real.
RESEND_API_KEY=
# Sender on a Resend-verified domain (kr8mx.com). Optional; defaults to
# "KR8MX <no-reply@kr8mx.com>".
RESEND_FROM=

# --- Payments (dormant until set) ---
# NOTE: KR8MX is kratom-derived. Stripe/mainstream processors typically prohibit
# it — launch requires a HIGH-RISK merchant account (e.g. First Citizens). The
# Stripe module is a dormant reference; without keys, checkout creates orders in
# `awaiting_payment` and charges nothing. Stripe TEST keys can validate the flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
