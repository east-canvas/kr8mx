# KR8MX environment

# --- Active ---
# Neon Postgres connection string (Drizzle ORM, COA + barcode admin, carts).
DATABASE_URL=

# --- Needed to enable the Nature's Bridge admin console (/admin) ---
# Single shared admin password. If unset, the admin is locked (secure default).
ADMIN_PASSWORD=

# --- Optional ---
# Base URL used when encoding dynamic barcodes (/q/{code}); defaults to
# https://kr8mx.com if unset.
NEXT_PUBLIC_SITE_URL=
